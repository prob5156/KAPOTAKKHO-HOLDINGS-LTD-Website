APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database Connection ──────────────────────────────────────────────────────
# Default: SQLite for local development (no extra setup required).
# For production (Oracle), set DB_CONNECTION=oracle and fill the Oracle block.
DB_CONNECTION=oracle

# ─── Oracle Database (Production) ────────────────────────────────────────────
# Prerequisites:
#   1. PHP OCI8 extension installed and enabled (php -m | grep oci8)
#   2. Oracle Instant Client libraries on system PATH / LD_LIBRARY_PATH
#   3. yajra/laravel-oci8 Composer package installed (see README.md)
#
# Option A – Host / Port / Service Name
# DB_CONNECTION=oracle
# DB_HOST=your-oracle-host-or-ip
# DB_PORT=1521
# DB_SERVICE_NAME=ORCL
# DB_DATABASE=ORCL
# DB_USERNAME=kapotakkho_user
# DB_PASSWORD=your_secure_password
# DB_CHARSET=AL32UTF8
# DB_PREFIX=
# DB_SCHEMA_PREFIX=
# DB_PERSISTENT=false
#
# Option B – Full TNS String (uncomment DB_TNS instead of host/port/service)
# DB_TNS=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=your-host)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)))
# ──────────────────────────────────────────────────────────────────────────────

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
